{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "framework": "nextjs",
      "routePrefix": "/",
      "maxDuration": 60
    },
    "backend": {
      "entrypoint": "backend/app/main.py",
      "framework": "fastapi",
      "routePrefix": "/api",
      "maxDuration": 300,
      "memory": 1024,
      "includeFiles": "backend/grounding/**"
    }
  }
}
