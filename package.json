{
  "name": "musica",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "vite build && node -e \"if (!process.env.VERCEL) { require('child_process').execSync('esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist/server.cjs', { stdio: 'inherit' }); }\"",
    "start": "node dist/server.cjs",
    "clean": "node -e \"const fs=require('fs'); for (const p of ['dist','dist-electron']) fs.rmSync(p,{recursive:true,force:true});\"",
    "lint": "tsc --noEmit",
    "pc:start": "npm run electron:start",
    "pc:pack": "npm run build && electron-builder build --dir --config.directories.output=D:\\MusicaBuild\\dist-electron",
    "pc:installer": "npm run build && electron-builder build --config.directories.output=D:\\MusicaBuild\\dist-electron",
    "electron:start": "electron electron-main.cjs",
    "electron:dev": "concurrently -k \"tsx server.ts\" \"electron electron-main.cjs\"",
    "electron:pack": "npm run build && electron-builder build --dir",
    "electron:dist": "npm run build && electron-builder build",
    "android:add": "cap add android",
    "android:sync": "npm run build && cap sync android",
    "android:build": "npm run android:sync && cd android && gradlew.bat assembleDebug",
    "android:open": "cap open android"
  },
  "build": {
    "appId": "com.musica.app",
    "productName": "Musica",
    "files": [
      "dist/**/*",
      "build/**/*",
      "electron-main.cjs",
      "package.json"
    ],
    "icon": "build/icon",
    "directories": {
      "output": "dist-electron"
    },
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icon.ico"
    },
    "portable": {
      "artifactName": "Musica-Portable-${version}.${ext}"
    },
    "nsis": {
      "artifactName": "Musica-Setup-${version}.${ext}",
      "oneClick": false,
      "perMachine": false,
      "allowElevation": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Musica",
      "installerIcon": "build/icon.ico",
      "uninstallerIcon": "build/icon.ico"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  },
  "dependencies": {
    "@breezystack/lamejs": "^1.2.7",
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "concurrently": "^9.2.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "openai": "^6.39.0",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/multer": "^2.1.0",
    "@types/node": "^22.14.0",
    "electron": "^42.2.0",
    "autoprefixer": "^10.4.21",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
